{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "blakehparsons@gmail.com",
        "ascAppId": "6760428526",
        "appleTeamId": "CJV4T7G5Z9"
      }
    },
    "production": {
      "ios": {
        "appleId": "blakehparsons@gmail.com",
        "ascAppId": "6760428526",
        "appleTeamId": "CJV4T7G5Z9"
      }
    }
  }
}
